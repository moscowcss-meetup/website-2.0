---
import type { HTMLAttributes } from 'astro/types';
import { blockTitle, blockTitleWhite } from './BlockTitle.css';

// Тег — единственный источник правды: заменишь 'div' на 'span' 
// тип пропсов (HTMLAttributes<typeof Tag>) и разметка поменяются вместе. 
// Рассинхрон тега и типа невозможен by design.
const Tag = 'div';

interface Props extends HTMLAttributes<typeof Tag> {
  /** Белый текст и рамка — для тёмного фона */
  white?: boolean;
}

const { white = false, class: className, ...attrs } = Astro.props;
---
<Tag class:list={[blockTitle, white && blockTitleWhite, className]} {...attrs}>
  <slot />
</Tag>
