---
import type { HTMLAttributes } from 'astro/types';
import { blockTitle, blockTitleInverse } from './BlockTitle.css';

const Tag = 'div';

interface Props extends HTMLAttributes<typeof Tag> {
  /** Вариант оформления: светлый или для тёмного фона */
  tone?: 'default' | 'inverse';
}

const { tone = 'default', class: className, ...attrs } = Astro.props;
---
<Tag class:list={[tone === 'inverse' ? blockTitleInverse : blockTitle, className]} {...attrs}>
  <slot />
</Tag>
