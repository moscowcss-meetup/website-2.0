---
import type { HTMLAttributes } from 'astro/types';
import { root } from './WebsiteTitle.css';

// Тег — единственный источник правды: тип пропсов (HTMLAttributes<typeof Tag>)
// и разметка меняются вместе, рассинхрон невозможен by design. Семантически
// это h2, отдельный лишь дизайн (см. vars.font.shorthand.websiteTitle).
const Tag = 'h2';

interface Props extends HTMLAttributes<typeof Tag> {
  // свои дополнительные пропсы
}

const { class: className, ...attrs } = Astro.props;
---
<Tag class:list={[root, className]} {...attrs}>
  <slot />
</Tag>
