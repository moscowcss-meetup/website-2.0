---
import type { HTMLAttributes } from 'astro/types';
import { root } from './Paragraph.css';

// Тег — единственный источник правды: тип пропсов (HTMLAttributes<typeof Tag>)
// и разметка меняются вместе, рассинхрон невозможен by design.
const Tag = 'p';

interface Props extends HTMLAttributes<typeof Tag> {
  // свои дополнительные пропсы
}

const { class: className, ...attrs } = Astro.props;
---
<Tag class:list={[root, className]} {...attrs}>
  <slot />
</Tag>
