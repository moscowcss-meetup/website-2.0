---
import type { HTMLAttributes } from 'astro/types';
import { TG, TGSmall } from '@moscowcss/icons';
import { root, iconLarge, iconSmall } from './TgLinkButton.css';

const Tag = 'a';

interface Props extends HTMLAttributes<typeof Tag> {
  /** URL канала или чата в Telegram */
  href: string;
}

const { href, class: className, ...attrs } = Astro.props;
const moscowCSSTGHref = href ?? 'https://t.me/moscowcss';

---
<Tag href={moscowCSSTGHref} class:list={[root, className]} {...attrs}>
  <TG class={iconLarge} />
  <TGSmall class={iconSmall} />
</Tag>
