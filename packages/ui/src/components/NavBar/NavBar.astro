---
import type { HTMLAttributes } from 'astro/types';
import { Close } from '@moscowcss/icons';
import BurgerButton from '../BurgerButton';
import TgLinkButton from '../TgLinkButton';
import {
  root,
  burger,
  links,
  link,
  overlay,
  overlayClose,
  overlayCloseIcon,
  overlayLinks,
  overlayLink,
} from './NavBar.css';

const Tag = 'nav';
const MENU_ID = 'nav-menu';

const NAV_LINKS = [
  { href: '#registration', label: 'Регистрация' },
  { href: '#speakers', label: 'Спикеры' },
  { href: '#organizers', label: 'Орги' },
  { href: '#partners', label: 'Партнеры' },
  { href: '#address', label: 'Адрес' },
] as const;

interface Props extends HTMLAttributes<typeof Tag> {
  /** URL канала или чата в Telegram */
  telegramHref: string;
}

const { telegramHref, class: className, ...attrs } = Astro.props;

---

<Tag class:list={[root, className]} data-navbar {...attrs}>
  <div class={burger}>
    <BurgerButton controls={MENU_ID} />
  </div>
  <ul class={links}>
    {NAV_LINKS.map((item) => (
      <li>
        <a class={link} href={item.href}>
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <TgLinkButton
    href={telegramHref}
    aria-label="Telegram Moscow CSS"
    target="_blank"
    rel="noopener noreferrer"
  />
  <div id={MENU_ID} class={overlay} data-nav-menu hidden>
    <button type="button" class={overlayClose} aria-label="Закрыть меню" data-nav-close>
      <Close class={overlayCloseIcon} />
    </button>
    <ul class={overlayLinks} data-nav-links>
      {NAV_LINKS.map((item) => (
        <li>
          <a class={overlayLink} href={item.href}>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</Tag>

<script>
  import { setupNavBar } from './NavBar.client';

  document.querySelectorAll<HTMLElement>('[data-navbar]').forEach(setupNavBar);
</script>
