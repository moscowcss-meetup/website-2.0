---
import '@moscowcss/fonts';
import '@moscowcss/design-system';
import '../styles/global.css';
import NavBar from '@moscowcss/ui/components/NavBar';
import HeroSection from '../sections/HeroSection.astro';
import ProgramSection from '../sections/ProgramSection.astro';
import PartnerSection from '../sections/PartnerSection.astro';
import FAQSection from '../sections/FAQSection.astro';

const telegramHref = 'https://t.me/moscowcss';
---

<html lang="ru" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MoscowCSS Meetup</title>
  </head>
  <body>
    <NavBar telegramHref={telegramHref} />
    <main>
      <HeroSection />
      <ProgramSection />
      <PartnerSection />
      <FAQSection />
    </main>
  </body>
</html>
