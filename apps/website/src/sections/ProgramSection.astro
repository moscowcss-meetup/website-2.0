---
import BlockTitle from '@moscowcss/ui/components/BlockTitle';
import SpeakerAvatar from '@moscowcss/ui/components/SpeakerAvatar';
import { scheduleHint, scheduleItems } from '../data/schedule';
import type { ScheduleTalk } from '../data/schedule';
import {
  section,
  inner,
  header,
  hint,
  list,
  row,
  portraitColumn,
  time,
  talkMain,
  talkTitle,
  speakerName,
  speakerRole,
  description,
  activityRow,
  activityTitle,
} from './ProgramSection.css';

interface Props {
  id?: string;
}

const { id = 'program' } = Astro.props;

const isTalk = (item: (typeof scheduleItems)[number]): item is ScheduleTalk => item.type === 'talk';
---

<section class={section} id={id}>
  <div class={inner}>
    <div class={header}>
      <BlockTitle>Программа</BlockTitle>
      <p class={hint}>{scheduleHint}</p>
    </div>

    <ul class={list}>
      {
        scheduleItems.map((item) =>
          isTalk(item) ? (
            <li class={row}>
              <div class={portraitColumn}>
                <p class={time}>{item.time}</p>
                <SpeakerAvatar src={item.speaker.avatarSrc} alt={item.speaker.avatarAlt} />
              </div>
              <div class={talkMain}>
                <h3 class={talkTitle}>{item.title}</h3>
                <p class={speakerName}>{item.speaker.name}</p>
                <p class={speakerRole}>{item.speaker.role}</p>
              </div>
              <p class={description}>{item.description}</p>
            </li>
          ) : (
            <li class={activityRow}>
              <p class={time}>{item.timeRange}</p>
              <p class={activityTitle}>{item.title}</p>
            </li>
          ),
        )
      }
    </ul>
  </div>
</section>
