---
import CallToAction from '@moscowcss/ui/components/CallToAction';
import { Logo } from '@moscowcss/icons';
import { hero } from '../data/hero';
import {
  section,
  inner,
  intro,
  introHead,
  star,
  title,
  modes,
  modeItem,
  footer,
  details,
  meetupLine,
  infoLine,
  passportNote,
  ctaColumn,
  ctaButton,
  onlineNote,
} from './HeroSection.css';

interface Props {
  id?: string;
}

const { id = 'registration' } = Astro.props;
---

<section class={section} id={id}>
  <div class={inner}>
    <div class={intro}>
      <div class={introHead}>
        <Logo class={star} aria-hidden="true" />
        <h1 class={title}>{hero.title}</h1>
      </div>
      <ul class={modes}>
        {
          hero.modes.map((mode) => (
            <li class={modeItem}>{mode}</li>
          ))
        }
      </ul>
    </div>

    <div class={footer}>
      <div class={details}>
        <p class={meetupLine}>{hero.meetupLine}</p>
        <p class={infoLine}>{hero.dateTime}</p>
        <p class={infoLine}>{hero.address}</p>
        <p class={passportNote}>{hero.passportNote}</p>
      </div>
      <div class={ctaColumn}>
        <CallToAction class={ctaButton} href={hero.registrationHref}>
          Регистрация
        </CallToAction>
        <p class={onlineNote}>Для онлайн просмотра регистрация не нужна 
                              <br/>
                              <a href={hero.translationHref} target="_blank" rel="noopener noreferrer">Смотри трансляцию</a>
        </p>
      </div>
    </div>
  </div>
</section>
