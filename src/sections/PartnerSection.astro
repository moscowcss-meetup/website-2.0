---
import BlockTitle from '@moscowcss/ui/components/BlockTitle';
import FeatureCard from '@moscowcss/ui/components/FeatureCard';
import MapPlaceholder from '@moscowcss/ui/components/MapPlaceholder';
import MediaTile from '@moscowcss/ui/components/MediaTile';
import { LineVektor, QrCode, ZvukLogo } from '@moscowcss/icons';
import { directions, partnerBrand, partnerFeatures } from '../data/partner';
import partnerCardsWave from '../../public/assets/partner-cards-wave.svg?raw';
import {
  section,
  hero,
  heroWave,
  inner,
  partnerHeader,
  brandLogo,
  handle,
  tagline,
  qr,
  cardsRow,
  cardsGrid,
  directionsBlock,
  address,
  hints,
  mediaTitle,
  mediaRow,
  mapFrame,
  mediaTileFrame,
} from './PartnerSection.css';

interface Props {
  id?: string;
}

const { id = 'partners' } = Astro.props;
---

<section class={section} id={id}>
  <div class={hero}>
    <div class={heroWave} aria-hidden="true">
      <LineVektor />
    </div>
    <div class={inner}>
      <div class={partnerHeader}>
        <ZvukLogo class={brandLogo} aria-label={partnerBrand.name} role="img" />
        <QrCode class={qr} aria-label={`QR-код ${partnerBrand.handle}`} role="img" />
        <p class={handle}>{partnerBrand.handle}</p>
        <p class={tagline}>{partnerBrand.tagline}</p>
      </div>

      <div class={cardsRow}>
        <div class={cardsGrid}>
          {
            partnerFeatures.map((feature, index) => (
              <FeatureCard
                title={feature.title}
                description={feature.description}
                footnote={feature.footnote}
                waveIndex={index}
                waveSvg={partnerCardsWave}
              />
            ))
          }
        </div>
      </div>

      <div class={directionsBlock} id="address">
        <BlockTitle tone="inverse">Как добраться</BlockTitle>
        <p class={address}>Адрес: {directions.address}</p>
        <ul class={hints}>
          {directions.hints.map((hint) => (
            <li>{hint}</li>
          ))}
        </ul>
        <MapPlaceholder
          class={mapFrame}
          latitude={directions.map.latitude}
          longitude={directions.map.longitude}
          zoom={directions.map.zoom}
          caption={directions.map.caption}
        />
        <p class={mediaTitle}>{directions.routeMediaTitle}</p>
        <div class={mediaRow}>
          {
            directions.media.map((item) => (
              <MediaTile
                class={mediaTileFrame}
                kind={item.kind}
                src={item.src}
                poster={item.poster}
                alt={item.alt}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
